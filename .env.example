# ==============================================================================
# InfluencerHub — نموذج البيئة
# ==============================================================================
# انسخه إلى `.env` ثم املأ القيم. **لا تضع سرًّا حقيقيًّا هنا** فالملفّ متتبَّع.
#
#   cp .env.example .env && php artisan key:generate
#
# كان هذا الملفّ هيكل Laravel الافتراضي: SQLite وإنجليزية و`APP_NAME=Laravel`.
# والمشروع يعمل على PostgreSQL بالعربية، فمن اتّبعه كان يفشل عند أوّل هجرة.
#
# القسم الأوّل مستعمَل فعلًا. والقسم الأخير (التكاملات) **مُجهَّز لا مربوط**:
# لا مزوّد معتمَد بعد. انظر docs/EXTERNAL-BLOCKERS.md.
# ==============================================================================

# ---------- التطبيق ----------
APP_NAME=InfluencerHub
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8010

APP_LOCALE=ar
APP_FALLBACK_LOCALE=ar
APP_FAKER_LOCALE=ar_SA

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

# saas | dedicated
DEPLOYMENT_MODE=saas

# ---------- السجلّات ----------
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ---------- قاعدة البيانات (PostgreSQL — إلزامي) ----------
# المشروع يستعمل فهارس جزئية و`ilike`؛ لا يعمل على SQLite ولا MySQL.
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=influencerhub
DB_USERNAME=postgres
DB_PASSWORD=
DB_SSLMODE=prefer

# قاعدة الاختبارات — منفصلة، تُنشأ يدويًّا (انظر READ-ME-FIRST)
# DB_TEST_DATABASE=influencerhub_testing

# ---------- الجلسات والذاكرة والطوابير ----------
# كلّها `database` اليوم. Redis مُهيَّأ ولا يُستعمل — لا تُبدّله قبل قياس الحاجة.
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=database
CACHE_PREFIX=

QUEUE_CONNECTION=database
QUEUE_FAILED_DRIVER=database-uuids

BROADCAST_CONNECTION=log

# ---------- Redis (مُهيَّأ، غير مستعمَل) ----------
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

# ---------- البريد ----------
# محلّيًّا `log`: الرسائل ورموز التحقّق تُكتب في storage/logs، فيمكن إكمال
# التسجيل بلا مزوّد بريد.
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="no-reply@influencerhub.local"
MAIL_FROM_NAME="${APP_NAME}"

# ---------- التخزين ----------
# قرص `private` إلزامي: مستندات المطالبات وملفّات المبدعين تُخزَّن عليه.
FILESYSTEM_DISK=local

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=me-south-1
AWS_BUCKET=
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ---------- حدود التطبيق ----------
CREATOR_VIDEO_MAX_MB=512

# ---------- Sanctum ----------
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:8010,127.0.0.1,127.0.0.1:8010

# ---------- الواجهة ----------
VITE_APP_NAME="${APP_NAME}"

# ---------- بذور محلّية فقط ----------
# تُستعمل في `preview:seed` و`e2e:seed`. لا تُشغَّل على إنتاج.
PREVIEW_PASSWORD=
E2E_PASSWORD=

# ==============================================================================
# التكاملات — مُجهَّزة لا مربوطة
# ==============================================================================
# ⚠️ **لا مزوّد معتمَد رسميًّا بعد.** المتغيّرات محجوزة، والنظام لا يدّعي
# مزامنة ولا دفعًا حقيقيًّا قبل الاعتماد. docs/EXTERNAL-BLOCKERS.md
# ==============================================================================

# ---------- Google ----------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REFRESH_TOKEN=
GOOGLE_DRIVE_FOLDER_ID=

# ---------- منصّات التواصل ----------
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_REDIRECT_URI=

TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=

YOUTUBE_API_KEY=

SNAPCHAT_CLIENT_ID=
SNAPCHAT_CLIENT_SECRET=

X_API_KEY=
X_API_SECRET=
X_BEARER_TOKEN=

# ---------- الإعلانات ----------
META_ADS_APP_ID=
META_ADS_APP_SECRET=
META_ADS_ACCESS_TOKEN=

GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=

TIKTOK_ADS_APP_ID=
TIKTOK_ADS_SECRET=
TIKTOK_ADS_ACCESS_TOKEN=

SNAPCHAT_ADS_CLIENT_ID=
SNAPCHAT_ADS_CLIENT_SECRET=

# ---------- التجارة ----------
SALLA_CLIENT_ID=
SALLA_CLIENT_SECRET=
SALLA_WEBHOOK_SECRET=
SALLA_REDIRECT_URI="${APP_URL}/integrations/salla/callback"

ZID_CLIENT_ID=
ZID_CLIENT_SECRET=
ZID_WEBHOOK_SECRET=
ZID_REDIRECT_URI="${APP_URL}/integrations/zid/callback"

# ---------- المراسلة ----------
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_BUSINESS_ACCOUNT_ID=

SMS_PROVIDER=
SMS_API_KEY=
SMS_SENDER_NAME=

# ---------- الدفع ----------
# لا تنفيذ تحويل في النظام: «مدفوع» تُسجَّل يدويًّا بمرجع بعد تسوية حقيقية.
PAYMENT_PROVIDER=
MOYASAR_API_KEY=
TAP_SECRET_KEY=
HYPERPAY_ENTITY_ID=
HYPERPAY_ACCESS_TOKEN=

# ---------- الذكاء الاصطناعي ----------
AI_PROVIDER=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ---------- التحقّق من الهوية ----------
MOWTHOOQ_API_KEY=
MOWTHOOQ_BASE_URL=
