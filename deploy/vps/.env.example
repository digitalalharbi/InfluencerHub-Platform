SITE_ADDRESS=crmv2.influencerhub.io
ACME_EMAIL=admin@influencerhub.io

APP_NAME=InfluencerHub
APP_ENV=production
APP_KEY=base64:CHANGE_ME_GENERATE_ON_SERVER
APP_DEBUG=false
APP_URL=https://crmv2.influencerhub.io
ASSET_URL=https://crmv2.influencerhub.io
APP_LOCALE=ar
APP_FALLBACK_LOCALE=ar
APP_FAKER_LOCALE=ar_SA
DEPLOYMENT_MODE=saas

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=influencerhub_crmv2
DB_USERNAME=influencerhub_crmv2
DB_PASSWORD=CHANGE_ME_STRONG_DATABASE_PASSWORD
DB_SSLMODE=prefer

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.influencerhub.io

CACHE_STORE=database
QUEUE_CONNECTION=database
QUEUE_FAILED_DRIVER=database-uuids
BROADCAST_CONNECTION=log

SANCTUM_STATEFUL_DOMAINS=crmv2.influencerhub.io
VITE_APP_NAME="${APP_NAME}"

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=no-reply@influencerhub.io
MAIL_FROM_NAME="${APP_NAME}"

FILESYSTEM_DISK=local
CREATOR_VIDEO_MAX_MB=512

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_BUSINESS_ACCOUNT_ID=

AI_PROVIDER=
OPENAI_API_KEY=